pkgname="carbonio-curl"
pkgver="8.14.1" # renovate: datasource=github-releases depName=curl/curl
pkgrel="1"
pkgdesc="An URL retrieval utility and library"
arch=('aarch64' 'x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('curl')
depends__apt=(
  "carbonio-krb5"
  "carbonio-openssl"
  "libbrotli1"
  "zlib1g"
)
makedepends__apt=(
  "libbrotli-dev"
  "perl"
  "zlib1g-dev"
)
depends__yum=(
  "brotli"
  "carbonio-krb5"
  "carbonio-openssl"
  "zlib"
)
makedepends__yum=(
  "brotli-devel"
  "perl"
  "zlib-devel"
)
section="utils"
priority="optional"
options=('!libtool')
source=(
  "https://curl.haxx.se/download/curl-${pkgver}.tar.gz"
  "https://github.com/nss-dev/nss/raw/NSS_3_122_RTM/lib/ckfw/builtins/certdata.txt"
)
sha256sums=(
  '6766ada7101d292b42b8b15681120acd68effa4a9660935853cf6d61f0d984d4'
  '3b98d4e3ff57a326d9587c33633039c8c3a9cf0b55f7ca581d7598ff329eb1f3'
)

build() {
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"
  export CPPFLAGS="-I/opt/zextras/common/include"
  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig"

  _host_flag=""
  _build_flag=""
  if [ -n "${CROSS_COMPILE}" ]; then
    _host_flag="--host=${CROSS_COMPILE_HOST}"
    _build_flag="--build=$(gcc -dumpmachine)"
    # accept4 requires _GNU_SOURCE; cross-compiler sysroot needs it explicit
    export CFLAGS="${CFLAGS} -D_GNU_SOURCE"
    export CPPFLAGS="${CPPFLAGS} -D_GNU_SOURCE"
    export PKG_CONFIG_LIBDIR="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig:/usr/lib/${CROSS_COMPILE_HOST}/pkgconfig:/usr/share/pkgconfig"
    unset PKG_CONFIG_PATH
  fi

  cd "${srcdir}/curl-${pkgver}"

  ./configure \
    --prefix=/opt/zextras/common \
    --disable-ldap \
    --disable-ldaps \
    --disable-static \
    --enable-ipv6 \
    --with-ca-bundle=/opt/zextras/common/share/curl/ca-bundle.crt \
    --with-gssapi=/opt/zextras/common \
    --with-openssl=/opt/zextras/common \
    --with-zlib \
    --without-gnutls \
    --without-libidn2 \
    --without-libpsl \
    ${_host_flag} ${_build_flag}
  _jobs=$(($(nproc) / 2))
  [ "$_jobs" -lt 1 ] && _jobs=1
  make -j"$_jobs"
}

package() {
  cd "${srcdir}/curl-${pkgver}"
  make DESTDIR="${pkgdir}" install

  # make ca-bundle target is replaced with the script.
  # certdata.txt is retrieved directly from github, cause of
  # hg.mozilla.org unreliability.
  # mk-ca-bundle.pl `-n` relies on an already existent certdata.txt
  cp "${srcdir}/certdata.txt" .
  scripts/mk-ca-bundle.pl -n -b -l -u lib/ca-bundle.crt

  mkdir -p "${pkgdir}/opt/zextras/common/share/curl"
  cp -f lib/ca-bundle.crt "${pkgdir}/opt/zextras/common/share/curl/ca-bundle.crt"
}
