pkgname="carbonio-perl-crypt-openssl-bignum"
pkgver="0.09" # renovate: datasource=cpan depName=Crypt::OpenSSL::Bignum
pkgrel="1"
pkgdesc="OpenSSL multiprecision integer arithmetic for Crypt::OpenSSL::RSA"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-openssl"
  "perl"
)
depends__yum=(
  "carbonio-openssl"
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/K/KM/KMX/Crypt-OpenSSL-Bignum-${pkgver}.tar.gz"
)
sha256sums=('234e72fb8396d45527e6fd45e43759c5c3f3a208cf8f29e6a22161a996fd42dc')

build() {
  cd "${srcdir}/Crypt-OpenSSL-Bignum-${pkgver}"
  OPENSSL_PREFIX=/opt/zextras/common \
    perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5
  LD_RUN_PATH=/opt/zextras/common/lib make
}

package() {
  cd "${srcdir}/Crypt-OpenSSL-Bignum-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
