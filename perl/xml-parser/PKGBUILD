pkgname="carbonio-perl-xml-parser"
pkgver="2.54" # renovate: datasource=cpan depName=XML::Parser
pkgrel="1"
pkgdesc="A perl module for parsing XML documents"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-perl-libwww"
  "perl"
)
depends__yum=(
  "carbonio-perl-libwww"
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/T/TO/TODDR/XML-Parser-${pkgver}.tar.gz"
)
sha256sums=('803bcd50eaf1fda0820056bb1ec485cdd1c04bca680394879b5e6a0be35597c6')

build() {
  cd "${srcdir}/XML-Parser-${pkgver}"
  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5 LIBS="-L/opt/zextras/common/lib" INC="-I/opt/zextras/common/include"
  make
}

package() {
  cd "${srcdir}/XML-Parser-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
