pkgname="carbonio-perl-net-dns"
pkgver="1.54" # renovate: datasource=cpan depName=Net::DNS
pkgrel="1"
pkgdesc="Perl Interface to the Domain Name System"
arch=('any')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-perl-digest-hmac"
  "carbonio-perl-io-socket-ip"
  "carbonio-perl-net-libidn2"
  "perl"
)
depends__yum=(
  "carbonio-perl-digest-hmac"
  "carbonio-perl-io-socket-ip"
  "carbonio-perl-net-libidn2"
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/N/NL/NLNETLABS/Net-DNS-${pkgver}.tar.gz"
)
sha256sums=('7abe0e03e8eead04bfe432d0d90ec0dd61b8ba71afad324a9c76acc6a6fbe2a4')

build() {
  cd "${srcdir}/Net-DNS-${pkgver}"

  # Disable online tests in Makefile.PL (avoids network access during configure)
  sed -i 's/my $online_tests = .*/my $online_tests = 0;/' Makefile.PL || true

  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5
  make -j"$(( $(nproc) / 2 ))"
}

package() {
  cd "${srcdir}/Net-DNS-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
