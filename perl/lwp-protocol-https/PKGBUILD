pkgname="carbonio-perl-lwp-protocol-https"
pkgver="6.15" # renovate: datasource=cpan depName=LWP::Protocol::https
pkgrel="1"
pkgdesc="Provide https support for LWP::UserAgent"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-perl-io-socket-ssl"
  "carbonio-perl-libwww"
  "carbonio-perl-net-http"
  "perl"
)
depends__yum=(
  "carbonio-perl-io-socket-ssl"
  "carbonio-perl-libwww"
  "carbonio-perl-net-http"
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/O/OA/OALDERS/LWP-Protocol-https-${pkgver}.tar.gz"
)
sha256sums=('44eec2da147ba0511090871b0ca82f69794376bc31e8c76d1040961ba57f59b8')

build() {
  cd "${srcdir}/LWP-Protocol-https-${pkgver}"
  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5 LIBS="-L/opt/zextras/common/lib -lssl -lcrypto" INC="-I/opt/zextras/common/include"
  make
}

package() {
  cd "${srcdir}/LWP-Protocol-https-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
