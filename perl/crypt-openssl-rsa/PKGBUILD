pkgname="carbonio-perl-crypt-openssl-rsa"
pkgver="0.39" # renovate: datasource=cpan depName=Crypt::OpenSSL::RSA
pkgrel="1"
pkgdesc="RSA encoding and decoding, using the openSSL libraries"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-perl-crypt-openssl-bignum"
  "carbonio-perl-crypt-openssl-random"
  "carbonio-openssl"
  "perl"
)
depends__yum=(
  "carbonio-perl-crypt-openssl-bignum"
  "carbonio-perl-crypt-openssl-random"
  "carbonio-openssl"
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/T/TI/TIMLEGGE/Crypt-OpenSSL-RSA-${pkgver}.tar.gz"
  "remove-guess.patch"
)
sha256sums=(
  '2589eb4a46f9d30c2a4757969702b22d53cb7f7190d73603fb10eba7870b62f3'
  'ac50f9b09088ed0821a36a0396bf32143881d1a143e2901fd2fe9f8dedc379ba'
)

prepare() {
  cd "${srcdir}/Crypt-OpenSSL-RSA-${pkgver}"
  patch -Np1 -i "${srcdir}/remove-guess.patch"
}

build() {
  cd "${srcdir}/Crypt-OpenSSL-RSA-${pkgver}"
  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5 LIBS="-L/opt/zextras/common/lib -lssl -lcrypto" INC="-I/opt/zextras/common/include"
  LD_RUN_PATH=/opt/zextras/common/lib make
}

package() {
  cd "${srcdir}/Crypt-OpenSSL-RSA-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
