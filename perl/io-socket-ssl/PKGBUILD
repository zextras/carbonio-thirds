pkgname="carbonio-perl-io-socket-ssl"
pkgver="2.098" # renovate: datasource=cpan depName=IO::Socket::SSL
pkgrel="1"
pkgdesc="SSL sockets with IO::Socket interface"
arch=('aarch64' 'x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "carbonio-perl-socket"
  "carbonio-perl-io-socket-ip"
  "carbonio-perl-net-ssleay"
  "carbonio-perl-uri"
  "perl"
)
depends__yum=(
  "carbonio-perl-socket"
  "carbonio-perl-io-socket-ip"
  "carbonio-perl-net-ssleay"
  "carbonio-perl-uri"
  "perl"
  "perl-core"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/S/SU/SULLR/IO-Socket-SSL-${pkgver}.tar.gz"
)
sha256sums=('b38473be20256b1a06447dd6769ad162bfad6a258234ed2c7e2e1819c16c4df7')

build() {
  cd "${srcdir}/IO-Socket-SSL-${pkgver}"

  _cc_flag=""
  if [ -n "${CROSS_COMPILE}" ]; then
    # Export CC/LD before Makefile.PL so it generates the Makefile with the cross-compiler
    export CC="${CROSS_COMPILE}gcc"
    export LD="${CROSS_COMPILE}gcc"
    _cc_flag="CC=${CROSS_COMPILE}gcc LD=${CROSS_COMPILE}gcc"
    export ac_cv_func_malloc_0_nonnull=yes
    export ac_cv_func_realloc_0_nonnull=yes
  fi

  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5 LIBS="-L/opt/zextras/common/lib -lssl -lcrypto" INC="-I/opt/zextras/common/include"
  LD_RUN_PATH=/opt/zextras/common/lib make ${_cc_flag} -j"$(($(nproc) / 2))"
}

package() {
  cd "${srcdir}/IO-Socket-SSL-${pkgver}"
  make install DESTDIR="${pkgdir}"
  # Relocate arch-specific files from host arch dir to target arch dir
  if [ -n "${CROSS_COMPILE}" ] && [ -d "${pkgdir}/opt/zextras/common/lib/perl5/x86_64-linux-gnu-thread-multi" ]; then
    mkdir -p "${pkgdir}/opt/zextras/common/lib/perl5/aarch64-linux-gnu-thread-multi"
    cp -a "${pkgdir}/opt/zextras/common/lib/perl5/x86_64-linux-gnu-thread-multi/." \
      "${pkgdir}/opt/zextras/common/lib/perl5/aarch64-linux-gnu-thread-multi/"
    rm -rf "${pkgdir}/opt/zextras/common/lib/perl5/x86_64-linux-gnu-thread-multi"
  fi
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
