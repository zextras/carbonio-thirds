pkgname="carbonio-perl-compress-raw-zlib"
pkgver="2.218" # renovate: datasource=cpan depName=Compress::Raw::Zlib
pkgrel="1"
pkgdesc="Low-Level Interface to zlib compression library"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends__apt=(
  "perl"
)
depends__yum=(
  "perl-core"
  "perl"
)
section="libs"
priority="important"
source=(
  "https://cpan.metacpan.org/authors/id/P/PM/PMQS/Compress-Raw-Zlib-${pkgver}.tar.gz"
)
sha256sums=('7a3f042792f3a24bf44281a280001d45ce4b6a1db302a8bd554bdf1721bdd195')

build() {
  cd "${srcdir}/Compress-Raw-Zlib-${pkgver}"
  perl -I /opt/zextras/common/lib/perl5 Makefile.PL INSTALL_BASE=/opt/zextras/common \
    INSTALLSITEMAN1DIR=/opt/zextras/common/share/man/man1 INSTALLSITEMAN3DIR=/opt/zextras/common/share/man/man3 \
    LIB=/opt/zextras/common/lib/perl5
  make
}

package() {
  cd "${srcdir}/Compress-Raw-Zlib-${pkgver}"
  make install DESTDIR="${pkgdir}"
  find "${pkgdir}" -name '.packlist' -delete
  find "${pkgdir}" -name '*.pod' -delete
}
