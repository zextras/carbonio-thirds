pkgname="carbonio-pflogsumm"
pkgver="1.2.0" # renovate: datasource=repology depName=arch/pflogsumm
pkgrel="1"
pkgdesc="Postfix log entry summarizer"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('GPL-2.0-or-later')
depends=(
  "carbonio-perl-date-calc"
)
section="libs"
priority="important"
source=("https://athena.linxnet.com/downloads/pflogsumm-${pkgver}.tar.gz")
sha256sums=('82a1b5558aad4e15ba2b46124fccc6a56a55610d80b43df6eee5f5fb0677ea6b')

package() {
  cd "${srcdir}/pflogsumm-${pkgver}"
  install -Dm755 pflogsumm \
    "${pkgdir}/opt/zextras/common/bin/pflogsumm"
  sed -i -e '/=head1 NAME/ i use lib qw(/opt/zextras/common/lib/perl5);' \
    "${pkgdir}"/opt/zextras/common/bin/pflogsumm
}
