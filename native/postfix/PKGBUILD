_package() {
  cd "${srcdir}/postfix-${pkgver}"
  sh postfix-install -non-interactive-package install_root="${pkgdir}"

  install -Dm755 auxiliary/qshape/qshape.pl \
    "${pkgdir}"/opt/zextras/common/sbin/qshape.pl

  # systemd sysusers.d configuration
  install -Dm644 "${srcdir}/systemd-sysuser.conf" \
    "${pkgdir}/usr/lib/sysusers.d/carbonio-postfix.conf"

  # systemd tmpfiles.d configuration
  install -Dm644 "${srcdir}/systemd-tmpfile.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/${pkgname}.conf"

  cd "${pkgdir}"/opt/zextras/common/sbin
  rm -f newaliases
  rm -f mailq
  ln -s sendmail mailq
  ln -s sendmail newaliases
}

_package_systemd() {
  # systemd unit
  install -Dm644 "${srcdir}/${pkgname}.service" \
    "${pkgdir}/usr/lib/systemd/system/${pkgname}.service"
}

_postinst_apt() {
  if [ "$1" = "configure" ]; then
    # Create postfix users and groups via sysusers.d
    systemd-sysusers /usr/lib/sysusers.d/carbonio-postfix.conf >/dev/null 2>&1 || :

    # Create postfix directories and set SGID on binaries via tmpfiles.d
    systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-postfix.conf >/dev/null 2>&1 || :
  fi
}

_postinst_yum() {
  # Create postfix users and groups via sysusers.d
  systemd-sysusers /usr/lib/sysusers.d/carbonio-postfix.conf >/dev/null 2>&1 || :

  # Create postfix directories and set SGID on binaries via tmpfiles.d
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-postfix.conf >/dev/null 2>&1 || :
}

_postinst_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    systemctl enable carbonio-postfix.service &>/dev/null || :
  fi
}

_prerm_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl --no-reload disable --now carbonio-postfix.service &>/dev/null || :
  fi
}

prepare() {
  cd "${srcdir}/postfix-${pkgver}"
  patch -Np1 -i "${srcdir}/carbonio-postfix.patch"
  patch -Np1 -i "${srcdir}/sd_notify.patch"
  # Replace bin/postconf invocations in postfix-install with a POSIX shell
  # shim that reads from conf/makedefs.out and main.cf, so the target-arch
  # postconf binary is never executed on the build host during packaging.
  patch -Np1 -i "${srcdir}/carbonio-postfix-cross.patch"
}

build() {
  cd "${srcdir}/postfix-${pkgver}"

  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig"

  # Postfix embeds the full CC command (with all -I flags) into its Makefiles
  # via makedefs. If CC is set in the environment, make overrides the Makefile's
  # CC variable and loses all the include paths. We pass CC only to makedefs
  # (via _cross_make_vars) and clear it for the actual compilation make invocation.

  _cross_make_vars=""
  _cross_auxlibs=""
  if [ -n "${CROSS_COMPILE}" ]; then
    # makedefs tries to run the cross-compiled ICU test binary on the host,
    # which fails silently and falls back to -DNO_EAI. Replace the run test
    # with a compile-only check when cross-compiling.
    sed -i 's|if ./makedefs.test 2>/dev/null ; then|if true ; then # cross-compile: skip run test|' makedefs

    # Postfix makedefs uses uname -s/-r to detect OS type; kernel 7.x is unknown.
    # Wrap uname to report Linux 6.0 so makedefs picks the right SYSTYPE.
    # Scope the wrapper to srcdir so we don't pollute /tmp across builds.
    mkdir -p "${srcdir}/_uname_wrap"
    cp "${srcdir}/uname-wrap" "${srcdir}/_uname_wrap/uname"
    chmod +x "${srcdir}/_uname_wrap/uname"
    export PATH="${srcdir}/_uname_wrap:${PATH}"
    _cross_make_vars="CC=${CROSS_COMPILE}gcc AR=${CROSS_COMPILE}ar RANLIB=${CROSS_COMPILE}ranlib"
    _cross_auxlibs="-ldb"
  fi

  _auxlibs="-L/opt/zextras/common/lib \
	-lpcre -lldap -llber -llmdb -lmysqlclient -lsasl2 -lssl -lcrypto \
	-L/usr/lib -lz -lm -lpthread -lsystemd ${_cross_auxlibs}"

  make makefiles PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig" ${_cross_make_vars} \
    command_directory=/opt/zextras/common/sbin \
    daemon_directory=/opt/zextras/common/libexec \
    config_directory=/opt/zextras/common/conf \
    queue_directory=/opt/zextras/data/postfix/spool \
    sendmail_path=/opt/zextras/common/sbin/sendmail \
    newaliases_path=/opt/zextras/common/sbin/newaliases \
    mailq_path=/opt/zextras/common/sbin/mailq \
    manpage_directory=/opt/zextras/common/share/man \
    html_directory=no \
    readme_directory=no \
    shlib_directory=/opt/zextras/common/lib/postfix \
    meta_directory=/opt/zextras/common/share/postfix \
    sample_directory=no \
    default_database_type=lmdb \
    data_directory=/opt/zextras/data/postfix/data \
    CCARGS='\
  -DHAS_LDAP \
  -DHAS_MYSQL \
  -DNO_DB \
  -DUSE_CYRUS_SASL \
  -DHAS_LMDB \
  -DUSE_LDAP_SASL \
  -DUSE_SASL_AUTH \
  -DUSE_TLS \
  -DHAS_PCRE \
  -DUSE_SYSTEMD \
  -I/opt/zextras/common/include \
  -I/opt/zextras/common/include/mysql \
  -I/opt/zextras/common/include/sasl \
  -I/usr/include \
  -I/usr/include/pcre' \
    AUXLIBS="${_auxlibs}" \
    SHLIB_RPATH='\
  -Wl,-rpath,/opt/zextras/common/lib/postfix \
  -Wl,-rpath,/opt/zextras/common/lib \
  -L/opt/zextras/common/lib' \
    OPT='\
  -Wl,-rpath,/opt/zextras/common/lib \
  -L/opt/zextras/common/lib'

  # Postfix's makedefs embeds the full CC (with all -I flags) into the Makefiles.
  # The env CC=aarch64-linux-gnu-gcc (set by yap) would override the Makefile's CC
  # and lose all include paths. Patch all generated Makefiles to use 'override CC'
  # so the Makefile definition wins over the environment.
  find . -name Makefile ! -name Makefile.in | xargs -I{} sed -i 's/^CC\t=/override CC\t=/' {}

  make -j"$(($(nproc) / 2))"
}

package() {
  _package
  _package_systemd
}

