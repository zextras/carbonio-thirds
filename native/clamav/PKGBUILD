_package() {
  cd "${srcdir}"
  alien -t clamav-data-*.noarch.rpm

  cd "${srcdir}/clamav-${pkgver}"
  make DESTDIR="${pkgdir}" install

  mkdir -p "${pkgdir}/opt/zextras/data/clamav/db"
  tar -xvf "${srcdir}"/clamav-data-*.tgz \
    --strip-components=4 \
    -C "${pkgdir}/opt/zextras/data/clamav/db"

  find "${pkgdir}" -name '*.a' -delete
  find "${pkgdir}" -name '*.la' -delete

  rm -rf "${pkgdir}/usr"
  rm -rf "${pkgdir}/lib"
  rm -rf "${pkgdir}"/opt/zextras/common/bin/clamav-config
  if [ -d "${pkgdir}/opt/zextras/common/lib64" ]; then
    mv "${pkgdir}/opt/zextras/common/lib64" \
      "${pkgdir}/opt/zextras/common/lib"
  fi

  # systemd tmpfiles.d configuration
  install -Dm644 "${srcdir}/systemd-tmpfile.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/${pkgname}.conf"

  # systemd sysusers.d configuration
  install -Dm644 "${srcdir}/systemd-sysuser.conf" \
    "${pkgdir}/usr/lib/sysusers.d/${pkgname}.conf"

  # start install carbonio-clamav consul registration artifacts
  install -Dm755 "${srcdir}/carbonio-clamav" \
    "${pkgdir}/usr/bin/carbonio-clamav"

  install -Dm644 "${srcdir}/policies.json" \
    "${pkgdir}/etc/carbonio/clamav/service-discover/policies.json"

  install -Dm644 "${srcdir}/carbonio-clamav.hcl" \
    "${pkgdir}/etc/zextras/service-discover/carbonio-clamav.hcl"

  install -Dm644 "${srcdir}/intentions.json" \
    "${pkgdir}/etc/carbonio/clamav/service-discover/intentions.json"

  install -Dm644 "${srcdir}/service-protocol.json" \
    "${pkgdir}/etc/carbonio/clamav/service-discover/service-protocol.json"

  install -Dm755 "${srcdir}/211-carbonio-clamav-setup.sh" \
    "${pkgdir}/etc/zextras/pending-setups.d/211-carbonio-clamav-setup.sh"
  # end install carbonio-clamav consul registration artifacts
}

_package_systemd() {
  # systemd units
  install -Dm644 "${srcdir}/carbonio-antivirus.service" \
    "${pkgdir}/usr/lib/systemd/system/carbonio-antivirus.service"
  install -Dm644 "${srcdir}/carbonio-freshclam.service" \
    "${pkgdir}/usr/lib/systemd/system/carbonio-freshclam.service"
}

_postinst() {
  # Create users and groups via systemd-sysusers
  systemd-sysusers /usr/lib/sysusers.d/carbonio-clamav.conf >/dev/null 2>&1 || :
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-clamav.conf || :

  echo "======================================================"
  echo "Carbonio ClamAV installed successfully!"
  echo "You must run pending-setups to configure it correctly."
  echo "======================================================"
}

_postinst_legacy() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
    systemctl enable carbonio-clamav-sidecar.service >/dev/null 2>&1 || :
  fi
}

_postinst_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
    systemctl enable carbonio-antivirus.service >/dev/null 2>&1 || :
    systemctl enable carbonio-freshclam.service >/dev/null 2>&1 || :
    systemctl enable carbonio-clamav-sidecar.service >/dev/null 2>&1 || :
  fi
}

_prerm_legacy() {
  if [ -d /run/systemd/system ]; then
    systemctl --no-reload disable carbonio-clamav-sidecar.service >/dev/null 2>&1 || :
    systemctl stop carbonio-clamav-sidecar.service >/dev/null 2>&1 || :
  fi
}

_prerm_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl --no-reload disable --now carbonio-antivirus.service >/dev/null 2>&1 || :
    systemctl --no-reload disable --now carbonio-freshclam.service >/dev/null 2>&1 || :
    systemctl --no-reload disable --now carbonio-clamav-sidecar.service >/dev/null 2>&1 || :
  fi
}

prepare() {
  # Install rustup if not present
  if ! command -v rustup &>/dev/null; then
    echo "Installing rustup..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
    source "$HOME/.cargo/env"
  fi

  # Ensure stable toolchain is installed and set as default
  rustup default stable
  rustup update stable

  cd "${srcdir}/clamav-${pkgver}"
  patch -Np1 -i "${srcdir}/sd_notify.patch"
}

build() {
  # Add cargo to PATH
  export PATH="$HOME/.cargo/bin:$PATH"

  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib -L/opt/zextras/common/lib"
  export CPPFLAGS="-I/opt/zextras/common/include"
  cd "${srcdir}/clamav-${pkgver}"

  cmake . \
    -DCMAKE_INSTALL_PREFIX=/opt/zextras/common \
    -DCLAMAV_USER=zextras \
    -DCLAMAV_GROUP=zextras \
    -DAPP_CONFIG_DIRECTORY=/opt/zextras/conf \
    -DCVD_CERTS_DIRECTORY=/opt/zextras/conf/certs \
    -DENABLE_MILTER=false \
    -DENABLE_SYSTEMD=ON \
    -DENABLE_TESTS=OFF

  make -j16
}

package() {
  _package
  _package_systemd

  install -Dm644 "${srcdir}/carbonio-clamav-sidecar.service" \
    "${pkgdir}/usr/lib/systemd/system/carbonio-clamav-sidecar.service"
}

