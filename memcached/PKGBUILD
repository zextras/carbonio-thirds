prerm__rocky_8() {
  _prerm_legacy
}

prerm__rocky_9() {
  _prerm_systemd
}

prerm__ubuntu_jammy() {
  _prerm_legacy
}

prerm__ubuntu_noble() {
  _prerm_systemd
}

postrm() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}
