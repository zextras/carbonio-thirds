pkgname="carbonio-bdb"
pkgver="5.3.28" # renovate: datasource=repology depName=arch/db
pkgrel="3"
pkgdesc="The Berkeley DB embedded database system"
arch=('aarch64' 'x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https://github.com/zextras"
license=('Sleepycat AND BSD-3-Clause AND CDDL-1.0')
section="utils"
priority="optional"
options=('!libtool')
source=(
  "https://download.oracle.com/berkeley-db/db-${pkgver}.tar.gz"
  "atomic.patch"
)
sha256sums=('e0a992d740709892e81f9d93f06daf305cf73fb81b545afe72478043172c3628'
  'ba0e2b4f53e9cb0ec58f60a979b53b8567b4565f0384886196f1fc1ef111d151')

build() {
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib"
  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig"
  cd "${srcdir}/db-${pkgver}"
  patch -p0 -i "${srcdir}/atomic.patch"

  # db-5.3.28's bundled config.sub (2012) doesn't recognize aarch64-*.
  # Only needed under cross-compile; native builds work with the bundled file.
  # Debian/Ubuntu: /usr/share/misc/; RHEL/Rocky: /usr/share/automake-*/.
  if [ -n "${CROSS_COMPILE}" ]; then
    for _f in config.sub config.guess; do
      _src=""
      for _p in /usr/share/misc/$_f /usr/share/automake-*/$_f /usr/share/libtool/build-aux/$_f; do
        [ -f "$_p" ] && {
          _src="$_p"
          break
        }
      done
      [ -n "$_src" ] || {
        echo "bdb: cannot find $_f on host" >&2
        exit 1
      }
      cp "$_src" "dist/$_f"
    done
  fi

  cd build_unix

  _host_flag=""
  _build_flag=""
  if [ -n "${CROSS_COMPILE}" ]; then
    _host_flag="--host=${CROSS_COMPILE_HOST}"
    _build_flag="--build=$(gcc -dumpmachine)"
    export PKG_CONFIG_LIBDIR="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig:/usr/lib/${CROSS_COMPILE_HOST}/pkgconfig:/usr/share/pkgconfig"
    unset PKG_CONFIG_PATH
  fi

  ../dist/configure \
    --prefix=/opt/zextras/common \
    --enable-compat185 \
    --enable-shared \
    --disable-static \
    --enable-cxx \
    --enable-dbm \
    --enable-stl \
    --disable-test \
    ${_host_flag} ${_build_flag}

  make LIBSO_LIBS=-lpthread
}

package() {
  cd "${srcdir}/db-${pkgver}"
  cd build_unix
  make DESTDIR="${pkgdir}" install
  rm -r "${pkgdir}"/opt/zextras/common/docs
}
