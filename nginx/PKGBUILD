_package() {
  cd "${srcdir}/nginx-${pkgver}"
  make DESTDIR="${pkgdir}" install
  mkdir -p "${pkgdir}"/opt/zextras/data/nginx
  mv "${pkgdir}"/opt/zextras/common/html "${pkgdir}"/opt/zextras/data/nginx/

  # lua-resty-core and lua-resty-lrucache libraries
  cd "${srcdir}/lua-resty-core"
  make install DESTDIR="${pkgdir}" LUA_LIB_DIR=/opt/zextras/common/share/lua/5.1
  cd "${srcdir}/lua-resty-lrucache"
  make install DESTDIR="${pkgdir}" LUA_LIB_DIR=/opt/zextras/common/share/lua/5.1

  # systemd tmpfiles.d configuration
  install -Dm644 "${srcdir}/systemd-tmpfile.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/${pkgname}.conf"

  rm -rf "${pkgdir}/run"
}

_package_systemd() {
  # systemd unit
  install -Dm644 "${srcdir}/${pkgname}.service" \
    "${pkgdir}/usr/lib/systemd/system/${pkgname}.service"
}

_postinst() {
  # Apply tmpfiles.d configuration
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-nginx.conf >/dev/null 2>&1 || :

  # Set permissions and capabilities on nginx binary
  # Note: On fresh install, zextras group may not exist yet (created by carbonio-core).
  # In that case, carbonio-core's postinst will set these permissions.
  # On upgrade/reinstall, zextras exists and we can set permissions here.
  if getent group zextras >/dev/null 2>&1; then
    # Note: chmod resets capabilities, so setcap must run after chmod
    chown root:zextras /opt/zextras/common/sbin/nginx
    chmod 750 /opt/zextras/common/sbin/nginx
    setcap CAP_NET_BIND_SERVICE=+ep /opt/zextras/common/sbin/nginx
  fi
}

_postinst_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    systemctl enable carbonio-nginx.service &>/dev/null || :
  fi
}

_prerm_systemd() {
  if [ -d /run/systemd/system ]; then
    systemctl --no-reload disable --now carbonio-nginx.service &>/dev/null || :
  fi
}

prepare() {
  cd "${srcdir}/nginx-brotli"
  # git submodule update only needed when cloned as a git repo;
  # yap downloads sources as tarballs so deps/brotli is already present
  if [ -d .git ]; then
    git submodule update --init --recursive
  fi

  cd "${srcdir}/nginx-${pkgver}"
  patch -Np1 --forward -r - -i "${srcdir}/${pkgname}-${pkgver}.patch" || [ $? -eq 1 ]
  patch -Np1 --forward -r - -i "${srcdir}/sd_notify.patch" || [ $? -eq 1 ]

  cd "${srcdir}/lua-nginx-module"
  patch -Np1 --forward -r - -i "${srcdir}/lua_default_path.patch" || [ $? -eq 1 ]
  patch -Np1 --forward -r - -i "${srcdir}/lua_luajit_warning.patch" || [ $? -eq 1 ]

  cd "${srcdir}/stream-lua-nginx-module"
  patch -Np1 --forward -r - -i "${srcdir}/stream_lua_default_path.patch" || [ $? -eq 1 ]
  patch -Np1 --forward -r - -i "${srcdir}/stream_lua_luajit_warning.patch" || [ $? -eq 1 ]
}

build() {
  export CFLAGS="-g -O2 -ffile-prefix-map=${srcdir}=. -fdebug-prefix-map=/etc=. -fstack-protector-strong"
  export LDFLAGS="-Wl,-rpath,/opt/zextras/common/lib -L/opt/zextras/common/lib -L/opt/zextras/common/lib64"
  export PKG_CONFIG_PATH="/opt/zextras/common/lib/pkgconfig:/opt/zextras/common/lib64/pkgconfig"
  export LUAJIT_INC="$(pkg-config --variable=includedir luajit)"
  export LUAJIT_LIB="$(pkg-config --variable=libdir luajit)"

  _nginx_cross_flags=""
  if [ -n "${CROSS_COMPILE}" ] && echo "${CROSS_COMPILE}" | grep -q "aarch64"; then
    # Set CPP as env var (nginx's --with-cpp= can't handle spaces in the value)
    export CPP="${CROSS_COMPILE}gcc -E"
    # Use arm64 LuaJIT libraries for cross-compilation
    export LUAJIT_INC="/usr/include/luajit-2.1"
    export LUAJIT_LIB="/usr/lib/aarch64-linux-gnu"
    _nginx_cross_flags="--crossbuild=Linux:aarch64 --with-cc=${CROSS_COMPILE}gcc"

    # Force ngx_feature_run=no: target-arch test binaries can't run on the build host
    # (configure would report "found but is not working" and abort).
    sed -i 's|^if \[ -x \$NGX_AUTOTEST \]; then$|ngx_feature_run=no\n&|' \
      "${srcdir}/nginx-${pkgver}/auto/feature"
    grep -q '^ngx_feature_run=no$' "${srcdir}/nginx-${pkgver}/auto/feature" || {
      echo "nginx: auto/feature cross patch did not apply — upstream may have changed" >&2
      exit 1
    }

    # auto/types/sizeof execs the target-arch test binary; replace with a
    # hardcoded aarch64 LP64 size table for every type queried from auto/unix.
    sed -i '/^if \[ -x \$NGX_AUTOTEST \]; then$/,/^fi$/c\
case "$ngx_type" in\
    "int"|"sig_atomic_t") ngx_size=4 ;;\
    "long"|"long long"|"void *"|"size_t"|"off_t"|"time_t") ngx_size=8 ;;\
    *) [ -x "$NGX_AUTOTEST" ] \&\& ngx_size=`$NGX_AUTOTEST` ;;\
esac\
echo " $ngx_size bytes (crossbuild aarch64)"' \
      "${srcdir}/nginx-${pkgver}/auto/types/sizeof"
    grep -q 'crossbuild aarch64' "${srcdir}/nginx-${pkgver}/auto/types/sizeof" || {
      echo "nginx: auto/types/sizeof cross patch did not apply — upstream may have changed" >&2
      exit 1
    }

    # nginx-brotli hardcodes -L<bundled>/out for brotli libs; cross-build brotli
    # for aarch64 using cmake toolchain and place libs in the expected out/ dir
    _brotli_src="${srcdir}/nginx-brotli/deps/brotli"
    mkdir -p "${_brotli_src}/out"
    cmake -S "${_brotli_src}" -B "${_brotli_src}/out" \
      -DCMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE}" \
      -DCMAKE_BUILD_TYPE=Release \
      -DBROTLI_DISABLE_TESTS=ON \
      -Wno-dev
    _jobs=$(($(nproc) / 2))
    [ "$_jobs" -lt 1 ] && _jobs=1
    make -C "${_brotli_src}/out" -j"$_jobs"
  fi

  cd "${srcdir}/nginx-${pkgver}"
  ./configure \
    --add-module="${srcdir}/ngx_devel_kit" \
    --add-module="${srcdir}/lua-nginx-module" \
    --add-module="${srcdir}/lua-resty-openssl-aux-module" \
    --add-module="${srcdir}/nginx-brotli" \
    --add-module="${srcdir}/stream-lua-nginx-module" \
    --add-module="${srcdir}/modules/http/sso" \
    --add-module="${srcdir}/modules/http/upstreamzmauth" \
    --add-module="${srcdir}/modules/mail/zmauth" \
    --add-module="${srcdir}/modules/mail/throttle" \
    --error-log-path=/opt/zextras/log/nginx.log \
    --http-log-path=/opt/zextras/log/nginx.access.log \
    --http-client-body-temp-path=/opt/zextras/data/tmp/nginx/client \
    --http-proxy-temp-path=/opt/zextras/data/tmp/nginx/proxy \
    --http-fastcgi-temp-path=/opt/zextras/data/tmp/nginx/fastcgi \
    --pid-path=/run/carbonio/nginx.pid \
    --prefix=/opt/zextras/common \
    --with-cc-opt="-g -I/opt/zextras/common/include -I${srcdir}/lua-nginx-module/src -DNGX_HAVE_SYSTEMD=1" \
    --with-ld-opt="-Wl,-rpath,/opt/zextras/common/lib -L/opt/zextras/common/lib -L/opt/zextras/common/lib64 -lsystemd" \
    --with-pcre \
    --with-http_addition_module \
    --with-http_auth_request_module \
    --with-http_degradation_module \
    --with-http_gunzip_module \
    --with-http_gzip_static_module \
    --with-http_secure_link_module \
    --with-http_slice_module \
    --with-http_ssl_module \
    --with-http_stub_status_module \
    --with-http_sub_module \
    --with-http_v2_module \
    --with-stream \
    --with-stream_ssl_module \
    --with-stream_ssl_preread_module \
    --with-threads \
    --with-mail \
    --with-mail-sasl \
    --with-mail_ssl_module \
    --without-http_scgi_module \
    --without-http_uwsgi_module \
    ${_nginx_cross_flags}
  _jobs=$(($(nproc) / 2))
  [ "$_jobs" -lt 1 ] && _jobs=1
  make -j"$_jobs"
}

